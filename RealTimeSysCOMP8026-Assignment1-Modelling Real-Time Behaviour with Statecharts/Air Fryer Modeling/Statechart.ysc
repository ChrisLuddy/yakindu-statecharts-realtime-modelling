  <sgraph:Statechart xmi:id="_6UhBUAtNEfGMbqt0jGIx1g" specification="@CycleBased(200)&#xA;@SuperSteps(no)&#xA;&#xA;interface:&#xA;&#x9;// User input events&#xA;&#x9;in event powerButton         // Turn on/off&#xA;&#x9;in event selectChicken       // Select chicken preset&#xA;&#x9;in event selectFish          // Select fish preset&#xA;&#x9;in event selectPotatoes      // Select potato preset&#xA;&#x9;in event selectVeggies       // Select vegetables preset&#xA;&#x9;in event startCooking        // Start button pressed&#xA;&#x9;in event stopCooking         // Stop/Cancel button&#xA;&#x9;in event openBasket          // User opens the basket&#xA;&#x9;in event closeBasket         // User closes the basket&#xA;&#x9;in event shakeFood           // User shakes the basket (for even cooking)&#xA;&#x9;&#xA;&#x9;// Manual controls&#xA;&#x9;in event increaseTemp        // Increase temperature&#xA;&#x9;in event decreaseTemp        // Decrease temperature&#xA;&#x9;in event increaseTime        // Increase cooking time&#xA;&#x9;in event decreaseTime        // Decrease cooking time&#xA;&#x9;&#xA;&#x9;// System variables&#xA;&#x9;var currentTemp: integer = 0              // Current temperature (°C)&#xA;&#x9;var targetTemp: integer = 200             // Target temperature (°C)&#xA;&#x9;var cookingTime: integer = 0              // Cooking time in minutes&#xA;&#x9;var timeRemaining: integer = 0            // Time left in minutes&#xA;&#x9;var presetSelected: integer = 0           // 0=none, 1=chicken, 2=fish, 3=potatoes, 4=veggies&#xA;&#x9;var basketOpen: boolean = false       // Is basket open?&#xA;&#x9;var isPaused: boolean = false         // Is cooking paused?&#xA;&#x9;var foodReady: boolean = false        // Is food ready?&#xA;&#x9;var needsShaking: boolean = false     // Mid-cooking shake reminder&#xA;&#xA;internal:&#xA;&#x9;// Internal events&#xA;&#x9;event preheatingComplete      // Preheating finished&#xA;&#x9;event cookingComplete         // Cooking finished&#xA;&#x9;event temperatureReached      // Target temp reached&#xA;&#x9;event midCookingAlert         // Time to shake food&#xA;&#x9;event beep                    // Beep sound&#xA;&#x9;event displayReady            // Display &quot;READY&quot; message&#xA;&#x9;event coolDown                // Cooling down after cooking" name="Statechart">
